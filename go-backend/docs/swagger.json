{
    "swagger": "2.0",
    "info": {
        "description": "API для музыкального сервиса \"Пивчики\"",
        "title": "Pivchiki API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/profile": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Возвращает полную информацию о профиле на основе ID из JWT токена",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "profile"
                ],
                "summary": "Получить профиль текущего пользователя",
                "responses": {
                    "200": {
                        "description": "Успешное получение профиля",
                        "schema": {
                            "$ref": "#/definitions/domain.FullProfile"
                        }
                    },
                    "400": {
                        "description": "Профиль не найден",
                        "schema": {
                            "$ref": "#/definitions/delivery.ErrorMsg"
                        }
                    },
                    "401": {
                        "description": "Вы не авторизованы",
                        "schema": {
                            "$ref": "#/definitions/delivery.ErrorMsg"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "delivery.ErrorMsg": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "domain.FullProfile": {
            "type": "object",
            "properties": {
                "aboutUser": {
                    "type": "string"
                },
                "age": {
                    "type": "integer"
                },
                "city": {
                    "type": "string"
                },
                "contact": {
                    "type": "string"
                },
                "genres": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "id": {
                    "type": "integer",
                    "format": "int64"
                },
                "instruments": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/domain.Instrument"
                    }
                },
                "isVisible": {
                    "type": "boolean"
                },
                "link": {
                    "type": "string"
                },
                "performancExperience": {
                    "type": "string"
                },
                "proficiencyLevel": {
                    "type": "integer"
                },
                "theoryLevel": {
                    "type": "integer"
                },
                "userName": {
                    "type": "string"
                }
            }
        },
        "domain.Instrument": {
            "type": "object",
            "properties": {
                "instrument": {
                    "type": "string"
                },
                "instrumentProficiencyLevel": {
                    "type": "integer"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "Введите JWT токен в формате: Bearer \u003cваш_токен\u003e",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}